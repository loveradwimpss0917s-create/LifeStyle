{
  "ci": {
    "collect": {
      "staticDistDir": "./dist",
      "url": [
        "http://localhost/index.html",
        "http://localhost/products/drip-kettle/index.html",
        "http://localhost/articles/drip-kettle-half-year-review/index.html",
        "http://localhost/quiz/index.html",
        "http://localhost/favorites/index.html",
        "http://localhost/ranking/index.html"
      ],
      "settings": {
        "preset": "desktop"
      }
    },
    "assert": {
      "assertMatrix": [
        {
          "matchingUrlPattern": "^(?!.*/favorites/).*$",
          "assertions": {
            "categories:performance": ["error", { "minScore": 0.95 }],
            "categories:accessibility": ["error", { "minScore": 0.95 }],
            "categories:best-practices": ["error", { "minScore": 0.95 }],
            "categories:seo": ["error", { "minScore": 0.95 }]
          }
        },
        {
          "matchingUrlPattern": ".*/favorites/.*",
          "assertions": {
            "categories:performance": ["error", { "minScore": 0.75 }],
            "categories:accessibility": ["error", { "minScore": 0.95 }],
            "categories:best-practices": ["error", { "minScore": 0.95 }],
            "categories:seo": ["error", { "minScore": 0.9 }]
          }
        }
      ]
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
