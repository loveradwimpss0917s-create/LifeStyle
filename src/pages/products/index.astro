---
/**
 * 商品一覧 — 02章§2
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumb from '@/components/base/Breadcrumb.astro';
import ProductGrid from '@/components/section/ProductGrid.astro';
import { getPublished } from '@/lib/content';

const products = (await getPublished('products')).sort(
  (a, b) => (b.data.publishedAt?.getTime() ?? 0) - (a.data.publishedAt?.getTime() ?? 0)
);
---

<BaseLayout title="商品一覧" description="実際に購入して使った商品の一覧です。">
  <div class="container">
    <Breadcrumb items={[{ label: 'Home', href: '/' }, { label: '商品一覧' }]} />
    <h1 class="page-heading">商品一覧</h1>
    {products.length > 0 ? (
      <div class="page-grid">
        <h2 class="visually-hidden">商品一覧</h2>
        <ProductGrid items={products} columns={4} />
      </div>
    ) : (
      <p class="page-empty">まだ商品がありません。</p>
    )}
  </div>
</BaseLayout>

<style>
  .page-heading {
    margin-top: var(--space-4);
    font-size: var(--text-3xl-mobile);
    text-wrap: balance;
  }

  @media (min-width: 768px) {
    .page-heading {
      font-size: var(--text-3xl);
    }
  }

  .page-grid {
    margin-top: var(--space-7);
  }

  .page-empty {
    margin-top: var(--space-6);
    color: var(--color-ink-tertiary);
  }
</style>
