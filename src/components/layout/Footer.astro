---
/**
 * Footer — 17章§2
 * 構成: ブランドブロック(シンボル+ワードマーク+タグライン) / カテゴリ / コンテンツ /
 * アバウト / SNSリンク / 罫線 / © + 英語タグライン
 * Newsletterは12章§6の方針によりV1では実装しない(先回り実装も行わない)。
 */
import BrandSymbol from '@/components/base/BrandSymbol.astro';
import SocialLinks from '@/components/content/SocialLinks.astro';
import { getAllCategoryNav } from '@/lib/nav';

const allCategoryNav = await getAllCategoryNav();
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer__inner container-wide">
    <div class="footer__brand">
      <p class="footer__logo">
        <BrandSymbol size={28} />
        <span>HIBISTACK</span>
      </p>
      <p class="footer__tagline">日々の暮らしを、少しだけ豊かにする。</p>
    </div>

    <nav class="footer__nav" aria-label="カテゴリ一覧">
      <p class="footer__nav-heading">カテゴリ</p>
      <ul role="list" class="footer__nav-list">
        {allCategoryNav.map((item) => (
          <li>
            <a href={item.href}>{item.labelJa}</a>
          </li>
        ))}
      </ul>
    </nav>

    <nav class="footer__nav" aria-label="コンテンツ">
      <p class="footer__nav-heading">コンテンツ</p>
      <ul role="list" class="footer__nav-list">
        <li><a href="/articles/">記事一覧</a></li>
        <li><a href="/products/">商品一覧</a></li>
        <li><a href="/ranking/">ランキング</a></li>
        <li><a href="/search/">検索</a></li>
      </ul>
    </nav>

    <nav class="footer__nav" aria-label="サイト情報">
      <p class="footer__nav-heading">About</p>
      <ul role="list" class="footer__nav-list">
        <li><a href="/about/">About</a></li>
        <li><a href="/privacy/">プライバシーポリシー</a></li>
        <li><a href="/disclosure/">アフィリエイト・PR表記について</a></li>
      </ul>
    </nav>

    <div class="footer__social">
      <SocialLinks variant="footer" />
    </div>

    <div class="footer__bottom">
      <p class="footer__copyright">&copy; {year} HIBISTACK</p>
      <p class="footer__tagline-en">Stacking better days.</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    margin-top: var(--section-gap);
    padding-block: var(--space-7);
    border-top: var(--border-thin);
    background: var(--color-bg-secondary);
  }

  .footer__inner {
    display: grid;
    gap: var(--space-6);
  }

  @media (min-width: 768px) {
    .footer__inner {
      grid-template-columns: 1.4fr 1fr 1fr 1fr;
      align-items: start;
    }
  }

  .footer__logo {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-en);
    font-size: var(--text-xl);
    font-weight: 600;
    letter-spacing: var(--tracking-wide);
    color: var(--color-ink);
  }

  .footer__tagline {
    margin-top: var(--space-2);
    font-size: var(--text-sm);
    color: var(--color-ink-tertiary);
  }

  .footer__nav-heading {
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-ink-tertiary);
  }

  .footer__nav-list {
    margin-top: var(--space-3);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    font-size: var(--text-sm);
    color: var(--color-ink-secondary);
  }

  .footer__nav-list a:hover {
    color: var(--color-ink);
  }

  .footer__social {
    grid-column: 1 / -1;
  }

  .footer__social :global(.social-links) {
    margin-left: -8px;
  }

  .footer__bottom {
    grid-column: 1 / -1;
    margin-top: var(--space-4);
    padding-top: var(--space-4);
    border-top: var(--border-thin);
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-2);
  }

  .footer__copyright {
    font-size: var(--text-xs);
    color: var(--color-ink-tertiary);
  }

  .footer__tagline-en {
    font-family: var(--font-en);
    font-size: var(--text-xs);
    font-style: italic;
    letter-spacing: var(--tracking-wide);
    color: var(--color-ink-tertiary);
  }
</style>
