---
/**
 * InstagramGrid — 17章§3⑧
 * 正方形サムネ6枚(D:3列2段/M:2列3段)+「@handleをフォローする」外部リンク。
 * Props: handle, images({src,alt}[6]), url(フォロー導線)
 */
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  handle: string;
  images: { src: ImageMetadata; alt: string }[];
  url: string;
}

const { handle, images, url } = Astro.props;
---

<div class="instagram-grid">
  <div class="instagram-grid__photos">
    {images.map((img) => (
      <div class="instagram-grid__photo">
        <Image src={img.src} alt={img.alt} width={480} height={480} />
      </div>
    ))}
  </div>
  <a href={url} target="_blank" rel="noopener noreferrer" class="instagram-grid__follow">
    {handle} をフォローする →
  </a>
</div>

<style>
  .instagram-grid__photos {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-2);
  }

  @media (min-width: 768px) {
    .instagram-grid__photos {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .instagram-grid__photo {
    aspect-ratio: 1 / 1;
    overflow: hidden;
    background: var(--color-bg-secondary);
  }

  .instagram-grid__photo :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--duration-base) var(--ease-out);
  }

  .instagram-grid__photo:hover :global(img) {
    transform: scale(1.02);
  }

  .instagram-grid__follow {
    display: inline-block;
    margin-top: var(--space-5);
    font-size: var(--text-sm);
    text-decoration: underline;
    text-underline-offset: 0.15em;
    color: var(--color-accent);
  }

  .instagram-grid__follow:hover {
    color: var(--color-accent-strong);
  }
</style>
