---
/**
 * Hero — 06章§6.4
 * Props: image, alt, labelEn, tagline
 * --container-wideの写真(16:9, priority load)+下部にラベル・タグライン。
 * labelEnはh1として描画する(トップページのみで使用する前提。他ページで
 * 再利用する場合はページ側の見出し階層と重複しないよう要注意)。
 */
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  image: ImageMetadata;
  alt: string;
  labelEn: string;
  tagline: string;
}

const { image, alt, labelEn, tagline } = Astro.props;
---

<section class="hero">
  <div class="container-wide">
    <div class="hero__media">
      <Image src={image} alt={alt} width={1920} height={1080} priority class="hero__image" />
    </div>
    <div class="hero__text">
      <h1 class="hero__label">{labelEn}</h1>
      <p class="hero__tagline">{tagline}</p>
    </div>
  </div>
</section>

<style>
  .hero {
    margin-top: var(--space-5);
  }

  .hero__media {
    aspect-ratio: 16 / 9;
    overflow: hidden;
  }

  .hero__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero__text {
    margin-top: var(--space-5);
  }

  .hero__label {
    font-family: var(--font-en);
    font-size: var(--text-xl);
    letter-spacing: var(--tracking-wide);
    color: var(--color-ink);
  }

  .hero__tagline {
    margin-top: var(--space-2);
    font-size: var(--text-lg);
    color: var(--color-ink-secondary);
  }

  /*
   * 初回ハードロード限定の入場演出(18章§2.2)。data-astro-rerunを付けない
   * scriptで.is-enteredを1回だけ付与するため、View Transitions経由の再訪では
   * 再生されない(スクリプト自体が再実行されないため)。
   */
  .hero__image {
    opacity: 0;
    transform: scale(1.03);
  }

  .hero__label,
  .hero__tagline {
    opacity: 0;
    transform: translateY(var(--motion-distance, 16px));
  }

  .hero.is-entered .hero__image {
    opacity: 1;
    transform: scale(1);
    transition:
      opacity var(--duration-slow) var(--ease-out),
      transform var(--duration-slow) var(--ease-out);
  }

  .hero.is-entered .hero__label {
    opacity: 1;
    transform: translateY(0);
    transition:
      opacity var(--duration-base) var(--ease-out) 100ms,
      transform var(--duration-base) var(--ease-out) 100ms;
  }

  .hero.is-entered .hero__tagline {
    opacity: 1;
    transform: translateY(0);
    transition:
      opacity var(--duration-base) var(--ease-out) 180ms,
      transform var(--duration-base) var(--ease-out) 180ms;
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__image,
    .hero__label,
    .hero__tagline {
      opacity: 1;
      transform: none;
    }
  }
</style>

<script is:inline>
  // Hero入場演出(18章§2.2)。data-astro-rerunを付けないため初回ハードロードで
  // 1度だけ実行される(View Transitions再訪ではこのscript自体が再実行されない
  // ので、意図通り再生されない)。二重rAFで初期スタイルの描画を確定させてから
  // is-enteredを付与し、transitionが確実に発火するようにする。
  (function () {
    var hero = document.querySelector('.hero');
    if (!hero) return;
    requestAnimationFrame(function () {
      requestAnimationFrame(function () {
        hero.classList.add('is-entered');
      });
    });
  })();
</script>
