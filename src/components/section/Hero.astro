---
/**
 * Hero — 06章§6.4
 * Props: image, alt, labelEn, tagline
 * --container-wideの写真(16:9, priority load)+下部にラベル・タグライン。
 * labelEnはh1として描画する(トップページのみで使用する前提。他ページで
 * 再利用する場合はページ側の見出し階層と重複しないよう要注意)。
 */
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  image: ImageMetadata;
  alt: string;
  labelEn: string;
  tagline: string;
}

const { image, alt, labelEn, tagline } = Astro.props;
---

<section class="hero">
  <div class="container-wide">
    <div class="hero__media">
      <Image src={image} alt={alt} width={1920} height={1080} priority class="hero__image" />
    </div>
    <div class="hero__text">
      <h1 class="hero__label">{labelEn}</h1>
      <p class="hero__tagline">{tagline}</p>
    </div>
  </div>
</section>

<style>
  .hero {
    margin-top: var(--space-5);
  }

  .hero__media {
    aspect-ratio: 16 / 9;
    overflow: hidden;
  }

  .hero__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero__text {
    margin-top: var(--space-5);
  }

  .hero__label {
    font-family: var(--font-en);
    font-size: var(--text-xl);
    letter-spacing: var(--tracking-wide);
    color: var(--color-ink);
  }

  .hero__tagline {
    margin-top: var(--space-2);
    font-size: var(--text-lg);
    color: var(--color-ink-secondary);
  }
</style>
