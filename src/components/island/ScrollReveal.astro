---
/**
 * ScrollReveal — 06章§6.5(演出・任意)
 * .reveal 要素にIntersectionObserverで is-visible を1回だけ付与する。
 * prefers-reduced-motion では即座に表示状態にする(観測自体を行わない)。
 * BaseLayoutで1回だけ読み込む(全体で3KB以下の軽量実装)。
 */
---

<script is:inline data-astro-rerun>
  // data-astro-rerun: View Transitions遷移後も.reveal要素を再取得するために必須
  // IIFEで包む: data-astro-rerunで同じスクリプトが再実行された際、トップレベルの
  // const/letはグローバルスコープで再宣言エラーになるため関数スコープに閉じ込める。
  (function () {
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const targets = document.querySelectorAll('.reveal');

    if (prefersReducedMotion || !('IntersectionObserver' in window)) {
      for (const el of targets) el.classList.add('is-visible');
    } else {
      const observer = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              observer.unobserve(entry.target);
            }
          }
        },
        { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
      );
      for (const el of targets) observer.observe(el);
    }
  })();
</script>
