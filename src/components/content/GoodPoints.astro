---
/**
 * GoodPoints — 06章§6.3
 * Props: points: string[]
 */
import Icon from '@/components/base/Icon.astro';

interface Props {
  points: string[];
}

const { points } = Astro.props;
---

<div class="points points--good">
  <h3 class="points__heading">良かった点</h3>
  <ul role="list" class="points__list">
    {points.map((point) => (
      <li class="points__item">
        <Icon name="check" size={18} class="points__icon" />
        <span>{point}</span>
      </li>
    ))}
  </ul>
</div>

<style>
  .points__heading {
    font-size: var(--text-lg);
  }

  .points__list {
    margin-top: var(--space-3);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .points__item {
    display: flex;
    align-items: flex-start;
    gap: var(--space-2);
    color: var(--color-ink-secondary);
  }

  /* :global が必要な理由: points__icon は子コンポーネント<Icon>のsvgルートへ
     classとして渡っているだけで、このコンポーネントのdata-astro-cidが
     付与されないためスコープ付きセレクタでは一致しない(RatingStars.astro
     と同じ既知のAstroスコープの制約)。 */
  .points--good :global(.points__icon) {
    flex-shrink: 0;
    margin-top: 2px;
    color: var(--color-accent);
  }
</style>
