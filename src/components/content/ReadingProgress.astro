---
/**
 * ReadingProgress — 17章§5
 * ビューポート最上部に固定した高さ2pxのバー。.article-body の読了率で伸長する。
 * 動きではなく情報表示のためreduced-motionでも表示するが、transitionは掛けない
 * (18章§2.8: スクロールに完全同期・easingを掛けない)。
 */
---

<div class="reading-progress" aria-hidden="true">
  <div class="reading-progress__bar" id="reading-progress-bar"></div>
</div>

<style>
  .reading-progress {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    z-index: 60;
  }

  .reading-progress__bar {
    height: 100%;
    width: 0%;
    background: var(--color-accent);
  }
</style>

<script is:inline data-astro-rerun>
  // ReadingProgress制御(18章§2.8)。.article-bodyのスクロール位置から読了率を計算。
  // data-astro-rerun: View Transitions遷移後も新しいDOM要素・状態で再設定するため必須。
  // IIFEで包む: トップレベルconst/letの再宣言エラーを避ける。
  // document.readyStateガード: inline scriptはHTMLパース中に出現順で即時実行される
  // ため、.article-bodyがこのscriptタグより後にある場合は初回ハードロード時に
  // まだDOMに存在しない可能性がある。パース未完了ならDOMContentLoadedまで遅延する。
  (function () {
    function run() {
      var bar = document.getElementById('reading-progress-bar');
      var article = document.querySelector('.article-body');
      if (!bar || !article) return;

      var ticking = false;

      function update() {
        var rect = article.getBoundingClientRect();
        var total = rect.height - window.innerHeight;
        var scrolled = -rect.top;
        var progress = total > 0 ? Math.min(1, Math.max(0, scrolled / total)) : 0;
        bar.style.width = progress * 100 + '%';
        ticking = false;
      }

      window.addEventListener(
        'scroll',
        function () {
          if (!ticking) {
            requestAnimationFrame(update);
            ticking = true;
          }
        },
        { passive: true }
      );

      update();
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', run);
    } else {
      run();
    }
  })();
</script>
