---
/**
 * AffiliateButton — 06章§6.2 / 26章c12
 * Props: product, mall, position(計測用ラベル。data-pos属性+/go/の?pos=に使う)
 * 挙動: URL未設定のモールは何も描画しない。rel="nofollow sponsored noopener"を必ず付与。
 * hrefは実URLではなく/go/{productId}/{mall}?pos={position}(クリック計測経由・26章c11)。
 * 直下に必ずPrLabelを描画する(12章§0不変条件2)。
 */
import Button from '@/components/base/Button.astro';
import PrLabel from '@/components/base/PrLabel.astro';
import { resolveAffiliateLink, buildGoUrl, type Mall } from '@/lib/affiliate';
import type { CollectionEntry } from 'astro:content';

interface Props {
  product: CollectionEntry<'products'>;
  mall: Mall;
  position: string;
  fullWidth?: boolean;
}

const { product, mall, position, fullWidth = true } = Astro.props;
const resolved = resolveAffiliateLink(product, mall);
const goUrl = resolved ? buildGoUrl(product.id, mall, position) : null;
---

{resolved && goUrl && (
  <div class="affiliate-button">
    <Button
      href={goUrl}
      external
      rel="nofollow sponsored noopener"
      variant="primary"
      size="lg"
      fullWidth={fullWidth}
      data-pos={position}
    >
      {resolved.label}
    </Button>
    <PrLabel />
  </div>
)}
