---
/**
 * ArticleCard — 06章§6.3
 * Props: article, variant: 'default' | 'large' | 'compact'
 */
import { getEntry, type CollectionEntry } from 'astro:content';
import { Image } from 'astro:assets';
import { formatDate } from '@/lib/format';

interface Props {
  article: CollectionEntry<'articles'>;
  variant?: 'default' | 'large' | 'compact';
}

const { article, variant = 'default' } = Astro.props;
const category = await getEntry(article.data.category);
const dateLabel = article.data.publishedAt ? formatDate(article.data.publishedAt) : undefined;
---

<article class:list={['article-card', `article-card--${variant}`]}>
  {variant !== 'compact' && (
    <div class="article-card__media">
      <Image
        src={article.data.heroImage}
        alt={article.data.heroAlt}
        width={variant === 'large' ? 800 : 480}
        height={variant === 'large' ? 533 : 320}
        class="article-card__image"
      />
    </div>
  )}
  <div class="article-card__body">
    <p class="article-card__category">{category.data.nameEn}</p>
    <h3 class="article-card__title">
      <a href={`/articles/${article.id}/`} class="stretched-link">{article.data.title}</a>
    </h3>
    {variant !== 'compact' && dateLabel && <p class="article-card__date">{dateLabel}</p>}
  </div>
</article>

<style>
  .article-card {
    position: relative;
  }

  .article-card--large {
    display: grid;
    gap: var(--space-5);
  }

  @media (min-width: 768px) {
    .article-card--large {
      grid-template-columns: 1.2fr 1fr;
      align-items: center;
    }
  }

  .article-card__media {
    aspect-ratio: 3 / 2;
    overflow: hidden;
    background: var(--color-bg-secondary);
  }

  .article-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--duration-base) var(--ease-out);
  }

  .article-card:hover .article-card__image {
    transform: scale(1.02);
  }

  .article-card__body {
    margin-top: var(--space-3);
  }

  .article-card--large .article-card__body {
    margin-top: 0;
  }

  .article-card__category {
    font-family: var(--font-en);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .article-card__title {
    margin-top: var(--space-2);
    font-size: var(--text-lg);
    line-height: var(--leading-tight);
    color: var(--color-ink);
  }

  .article-card--compact .article-card__title {
    font-size: var(--text-sm);
    font-weight: 400;
  }

  .article-card--large .article-card__title {
    font-size: var(--text-2xl);
  }

  .article-card__date {
    margin-top: var(--space-2);
    font-size: var(--text-xs);
    color: var(--color-ink-tertiary);
  }

  .stretched-link::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 1;
  }
</style>
