---
/**
 * BrandSymbol — 14章§2
 * HIBISTACKのシンボルロゴ(漢字「日」の幾何学的抽象: 角丸矩形+中線)。
 * currentColor単色のインラインSVG。viewBox 0 0 64 64。
 * Props: size(px, 既定24)
 */
interface Props {
  size?: number;
  class?: string;
}

const { size = 24, class: className } = Astro.props;
---

<svg
  class={className}
  width={size}
  height={size}
  viewBox="0 0 64 64"
  fill="none"
  stroke="currentColor"
  stroke-width="5"
  stroke-linecap="round"
  aria-hidden="true"
  focusable="false"
>
  <rect x="16" y="8" width="32" height="48" rx="7" />
  <path d="M16 32h32" />
</svg>
