---
/**
 * RatingStars — 06章§6.2
 * Props: rating(1-5), showNumber?
 */
import Icon from '@/components/base/Icon.astro';

interface Props {
  /** 1-5の範囲(products.rating)。範囲の強制はZodスキーマ側で行う(07章§4)。 */
  rating: number;
  showNumber?: boolean;
}

const { rating, showNumber = false } = Astro.props;
const stars = [1, 2, 3, 4, 5] as const;
---

<span class="rating-stars" role="img" aria-label={`おすすめ度 ${rating}/5`}>
  {stars.map((n) => (
    <Icon name="star" size={16} class:list={['rating-stars__star', { 'is-filled': n <= rating }]} />
  ))}
  {showNumber && <span class="rating-stars__number">{rating}/5</span>}
</span>

<style>
  .rating-stars {
    display: inline-flex;
    align-items: center;
    gap: 2px;
  }

  /*
   * :global が必要な理由: rating-stars__star は <Icon> に class として渡され、
   * Icon.astro側のsvgルート要素に付与される。Astroのスコープ付きCSSは
   * 「このコンポーネントのテンプレートに直接書かれた要素」にのみ
   * data-astro-cid-* を付与するため、子コンポーネントへclassとして
   * 転送しただけの要素にはスコープ属性が付かずスコープ付きセレクタが
   * マッチしない(is-filledの有無に関わらず全ての星が--color-ink-secondary
   * 等の継承色になり、おすすめ度が常に同じ色で表示されてしまう不具合の原因)。
   */
  :global(.rating-stars__star) {
    color: var(--color-line);
  }

  :global(.rating-stars__star.is-filled) {
    color: var(--color-star);
  }

  .rating-stars__number {
    margin-left: var(--space-2);
    font-size: var(--text-sm);
    color: var(--color-ink-tertiary);
  }
</style>
