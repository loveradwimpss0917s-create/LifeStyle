---
/**
 * BaseLayout — 06章§6.6
 * Props: title, description, ogImage?, jsonLd?, noindex?
 */
import { ClientRouter } from 'astro:transitions';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';
import ScrollReveal from '@/components/island/ScrollReveal.astro';
import '@/styles/global.css';
import fontsCssText from '@/styles/fonts.css?inline';
import cormorantLatinWoff2 from '@fontsource-variable/cormorant-garamond/files/cormorant-garamond-latin-wght-normal.woff2?url';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  noindex?: boolean;
}

const { title, description, ogImage, jsonLd, noindex = false } = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const siteName = 'HIBISTACK';
const pageTitle = title === siteName ? title : `${title} | ${siteName}`;
const resolvedOgImage = ogImage
  ? new URL(ogImage, Astro.site)
  : undefined;

const jsonLdList = jsonLd
  ? Array.isArray(jsonLd)
    ? jsonLd
    : [jsonLd]
  : [];

// Cloudflare Web Analytics(26章c1)。トークン未設定ならビーコンを一切出力しない
// (フォーク・ローカルビルドを壊さない)。トークンはCloudflareダッシュボード
// [Analytics & Logs > Web Analytics] で取得し、Pagesの環境変数に設定する(README参照)。
const cfBeaconToken = import.meta.env.PUBLIC_CF_BEACON_TOKEN;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#ffffff" id="theme-color-meta" />

    <!--
      ダークモード初期化(16章§1.3)。CSS読込前・head最上部付近で同期実行し、
      FOUC(一瞬ライトテーマが見えてから切り替わる現象)を防ぐ。theme-color-meta
      は直前で定義済みのためここで即座に更新できる。

      重要: <html>要素自体はView Transitions遷移をまたいで保持される、という
      当初の想定は誤りだった。Astroのswap処理は遷移先ページのSSR済みHTML
      (data-theme属性を持たない、常にサーバー側では未知の値のため)を基準に
      <html>の属性を再構築するため、data-astro-rerunなしではページ遷移の
      たびにdata-theme属性が失われ、ダークモードが解除されて見える不具合が
      発生していた(実機で確認)。
      修正: astro:before-swapイベントで遷移先ドキュメントへ現在のテーマを
      明示的にコピーする(Astro公式の推奨パターン)。このリスナーは
      documentに対して1回だけ登録すればよく、document自体はView Transitions
      をまたいで存在し続けるため、script自体にdata-astro-rerunは不要。
    -->
    <script is:inline>
      (function () {
        function applyTheme(theme) {
          document.documentElement.dataset.theme = theme;
          var meta = document.getElementById('theme-color-meta');
          if (meta) meta.setAttribute('content', theme === 'dark' ? '#161513' : '#ffffff');
        }

        function resolveTheme() {
          try {
            var stored = localStorage.getItem('hibistack:theme');
            if (stored === 'dark' || stored === 'light') return stored;
            return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
          } catch (e) {
            return 'light';
          }
        }

        applyTheme(resolveTheme());

        document.addEventListener('astro:before-swap', function (event) {
          var theme = document.documentElement.dataset.theme === 'dark' ? 'dark' : 'light';
          event.newDocument.documentElement.dataset.theme = theme;
          var newMeta = event.newDocument.getElementById('theme-color-meta');
          if (newMeta) newMeta.setAttribute('content', theme === 'dark' ? '#161513' : '#ffffff');
        });
      })();
    </script>

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/icons/favicon-48.png" type="image/png" sizes="48x48" />
    <link rel="apple-touch-icon" href="/icons/apple-touch-icon.png" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <link rel="canonical" href={canonicalURL} />
    <link rel="alternate" type="application/rss+xml" title={siteName} href="/rss.xml" />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <title>{pageTitle}</title>
    <meta name="description" content={description} />

    <!-- OGP -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    {resolvedOgImage && <meta property="og:image" content={resolvedOgImage} />}
    <meta name="twitter:card" content="summary_large_image" />

    <!-- フォントpreload(LCP付近で使用される英字フォントのみ。日本語フォントはunicode-range分割済みのため対象外) -->
    <link
      rel="preload"
      href={cormorantLatinWoff2}
      as="font"
      type="font/woff2"
      crossorigin="anonymous"
    />

    <!--
      フォント宣言(@font-face)。詳細は src/styles/fonts.css のコメント参照。
      以前はmedia=print+onload切替による非同期読み込みだったが、Lighthouseの
      render-blocking-resources監査はこの手法を使ってもなお当該linkを
      render-blocking扱いにするため、@font-faceルール数が6個(1.8KB)まで
      削減済み(コメント参照)であることを踏まえてインライン<style>に変更し、
      外部リクエスト自体をなくした(26章c29 Lighthouse実測での気づき)。
      preloadは付けない(実測で、大きなWOFF2ファイルのフェッチ優先度が上がり
      LCP対象の画像と帯域を奪い合ってLCPが悪化する挙動を確認したため)。
    -->
    <style set:html={fontsCssText} />

    {jsonLdList.map((entry) => (
      <script type="application/ld+json" set:html={JSON.stringify(entry)} is:inline />
    ))}

    {cfBeaconToken && (
      <script
        defer
        src="https://static.cloudflareinsights.com/beacon.min.js"
        data-cf-beacon={JSON.stringify({ token: cfBeaconToken, spa: true })}
        is:inline
      />
    )}

    <ClientRouter />
  </head>
  <body>
    <a href="#main-content" class="skip-link">メインコンテンツへスキップ</a>
    <Header />
    <main id="main-content" data-pagefind-body>
      <slot />
    </main>
    <Footer />
    <ScrollReveal />
  </body>
</html>
