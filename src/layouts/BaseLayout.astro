---
/**
 * BaseLayout — 06章§6.6
 * Props: title, description, ogImage?, jsonLd?, noindex?
 */
import { ClientRouter } from 'astro:transitions';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';
import ScrollReveal from '@/components/island/ScrollReveal.astro';
import '@/styles/global.css';
import fontsCssUrl from '@/styles/fonts.css?url';
import cormorantLatinWoff2 from '@fontsource-variable/cormorant-garamond/files/cormorant-garamond-latin-wght-normal.woff2?url';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  noindex?: boolean;
}

const { title, description, ogImage, jsonLd, noindex = false } = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const siteName = 'HIBISTACK';
const pageTitle = title === siteName ? title : `${title} | ${siteName}`;
const resolvedOgImage = ogImage
  ? new URL(ogImage, Astro.site)
  : undefined;

const jsonLdList = jsonLd
  ? Array.isArray(jsonLd)
    ? jsonLd
    : [jsonLd]
  : [];
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#ffffff" id="theme-color-meta" />

    <!--
      ダークモード初期化(16章§1.3)。CSS読込前・head最上部付近で同期実行し、
      FOUC(一瞬ライトテーマが見えてから切り替わる現象)を防ぐ。theme-color-meta
      は直前で定義済みのためここで即座に更新できる。
      data-astro-rerunは付けない: <html>要素自体はView Transitions遷移を
      またいで保持されるため、data-theme属性は自然に引き継がれる
      (再実行すると保存値の再読込になるだけで害はないが不要)。
    -->
    <script is:inline>
      (function () {
        try {
          var stored = localStorage.getItem('hibistack:theme');
          var theme =
            stored === 'dark' || stored === 'light'
              ? stored
              : window.matchMedia('(prefers-color-scheme: dark)').matches
                ? 'dark'
                : 'light';
          document.documentElement.dataset.theme = theme;
          var meta = document.getElementById('theme-color-meta');
          if (meta) meta.setAttribute('content', theme === 'dark' ? '#161513' : '#ffffff');
        } catch (e) {
          /* localStorage/matchMedia が使えない環境ではライト既定のまま */
        }
      })();
    </script>

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/icons/favicon-48.png" type="image/png" sizes="48x48" />
    <link rel="apple-touch-icon" href="/icons/apple-touch-icon.png" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <link rel="canonical" href={canonicalURL} />
    <link rel="alternate" type="application/rss+xml" title={siteName} href="/rss.xml" />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <title>{pageTitle}</title>
    <meta name="description" content={description} />

    <!-- OGP -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    {resolvedOgImage && <meta property="og:image" content={resolvedOgImage} />}
    <meta name="twitter:card" content="summary_large_image" />

    <!-- フォントpreload(LCP付近で使用される英字フォントのみ。日本語フォントはunicode-range分割済みのため対象外) -->
    <link
      rel="preload"
      href={cormorantLatinWoff2}
      as="font"
      type="font/woff2"
      crossorigin="anonymous"
    />

    <!--
      フォント宣言(@font-face)。詳細は src/styles/fonts.css のコメント参照。
      レンダーブロッキングを避けるため非同期読み込みにしている。
      preloadは付けない(実測で、大きなWOFF2ファイルのフェッチ優先度が上がり
      LCP対象の画像と帯域を奪い合ってLCPが悪化する挙動を確認したため)。
    -->
    <link rel="stylesheet" href={fontsCssUrl} media="print" onload="this.media='all'" />
    <noscript><link rel="stylesheet" href={fontsCssUrl} /></noscript>

    {jsonLdList.map((entry) => (
      <script type="application/ld+json" set:html={JSON.stringify(entry)} is:inline />
    ))}

    <ClientRouter />
  </head>
  <body>
    <a href="#main-content" class="skip-link">メインコンテンツへスキップ</a>
    <Header />
    <main id="main-content" data-pagefind-body>
      <slot />
    </main>
    <Footer />
    <ScrollReveal />
  </body>
</html>
