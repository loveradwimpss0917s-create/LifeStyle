---
/**
 * ArticleLayout — 04章§4.4
 * ①パンくず ②記事ヘッダー ③ヒーロー画像 ④本文(MDX+埋め込みコンポーネント)
 * ⑤PR表記(商品埋め込みがある場合) ⑥登場した商品まとめ ⑦次に読む ⑧同カテゴリの記事
 */
import { getEntry, render, type CollectionEntry } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumb from '@/components/base/Breadcrumb.astro';
import TagChip from '@/components/base/TagChip.astro';
import PrLabel from '@/components/base/PrLabel.astro';
import Prose from '@/components/base/Prose.astro';
import Callout from '@/components/base/Callout.astro';
import ProductCard from '@/components/content/ProductCard.astro';
import ProductEmbed from '@/components/content/ProductEmbed.astro';
import ComparisonTable from '@/components/content/ComparisonTable.astro';
import RankingItem from '@/components/content/RankingItem.astro';
import RankingList from '@/components/content/RankingList.astro';
import ArticleCard from '@/components/content/ArticleCard.astro';
import Toc from '@/components/content/Toc.astro';
import ReadingProgress from '@/components/content/ReadingProgress.astro';
import ShareRow from '@/components/content/ShareRow.astro';
import BackToTop from '@/components/content/BackToTop.astro';
import { formatDate } from '@/lib/format';
import { getRelatedArticles } from '@/lib/related';
import { getEmbeddedProductIds } from '@/lib/product-index';
import { buildArticleJsonLd, buildItemListJsonLd } from '@/lib/seo';

interface Props {
  article: CollectionEntry<'articles'>;
}

const { article } = Astro.props;
const { Content, headings } = await render(article);

const category = await getEntry(article.data.category);
const tags = article.data.tags.length
  ? await Promise.all(article.data.tags.map((t) => getEntry(t)))
  : [];

const embeddedProductIds = await getEmbeddedProductIds(article);
const embeddedProducts = embeddedProductIds.length
  ? (
      await Promise.all(embeddedProductIds.map((id) => getEntry('products', id)))
    ).filter((p): p is NonNullable<typeof p> => p !== undefined)
  : [];

const related = await getRelatedArticles(article, 4);
const nextArticle = related[0];
const sameCategoryArticles = related.slice(1, 4);

const dateLabel = article.data.publishedAt ? formatDate(article.data.publishedAt) : undefined;
const updatedLabel =
  article.data.updatedAt && article.data.updatedAt.getTime() !== article.data.publishedAt?.getTime()
    ? formatDate(article.data.updatedAt)
    : undefined;

const description = article.data.seo.description ?? article.data.lead;
const pageUrl = new URL(Astro.url.pathname, Astro.site).toString();

const articleJsonLd = await buildArticleJsonLd(article, Astro.site!);
const itemListJsonLd =
  (article.data.type === 'ranking' || article.data.type === 'roundup') && embeddedProducts.length > 0
    ? buildItemListJsonLd(
        embeddedProducts.map((p) => ({ url: `/products/${p.id}/`, name: p.data.name })),
        Astro.site!
      )
    : undefined;
const jsonLd = itemListJsonLd ? [articleJsonLd, itemListJsonLd] : articleJsonLd;
---

<BaseLayout
  title={article.data.title}
  description={description}
  ogImage={`/og/articles/${article.id}.png`}
  jsonLd={jsonLd}
  noindex={article.data.seo.noindex}
>
  <div
    class="container"
    data-pagefind-meta="type:記事"
    data-filter-type="記事"
    data-filter-category={category.data.nameJa}
    data-pagefind-filter="種類[data-filter-type], カテゴリ[data-filter-category]"
  >
    <Breadcrumb
      items={[
        { label: 'Home', href: '/' },
        { label: category.data.nameJa, href: `/categories/${category.id}/` },
        { label: article.data.title },
      ]}
    />
  </div>

  <header class="article-header container-text">
    <p class="article-header__category">{category.data.nameEn}</p>
    <h1 class="article-header__title">{article.data.title}</h1>
    <p class="article-header__lead">{article.data.lead}</p>
    <div class="article-header__meta">
      {dateLabel && <span>{dateLabel} 公開</span>}
      {updatedLabel && <span>{updatedLabel} 更新</span>}
    </div>
    {tags.length > 0 && (
      <div class="article-header__tags">
        {tags.map((tag) => <TagChip tag={tag} size="sm" />)}
      </div>
    )}
    {embeddedProducts.length > 0 && <PrLabel />}
  </header>

  <div class="article-hero container-wide">
    <Image src={article.data.heroImage} alt={article.data.heroAlt} width={1440} height={960} priority />
  </div>

  <article class="article-body container-text">
    <Toc headings={headings} />
    <Prose>
      <Content components={{ ProductEmbed, Callout, ComparisonTable, RankingItem, RankingList }} />
    </Prose>
    <ShareRow url={pageUrl} title={article.data.title} />
  </article>

  {embeddedProducts.length > 0 && (
    <section class="container article-section">
      <h2 class="article-section__heading">この記事に登場した商品</h2>
      <div class="article-section__scroll">
        {embeddedProducts.map((product) => (
          <div class="article-section__scroll-item">
            <ProductCard product={product} />
          </div>
        ))}
      </div>
    </section>
  )}

  {nextArticle && (
    <section class="container article-section">
      <h2 class="article-section__heading">次に読む</h2>
      <ArticleCard article={nextArticle} variant="large" />
    </section>
  )}

  {sameCategoryArticles.length > 0 && (
    <section class="container article-section">
      <h2 class="article-section__heading">{category.data.nameJa}の記事</h2>
      <div class="article-section__grid">
        {sameCategoryArticles.map((a) => <ArticleCard article={a} />)}
      </div>
    </section>
  )}

  <ReadingProgress />
  <BackToTop />
</BaseLayout>

<style>
  .container-text {
    max-width: var(--container-text);
    margin-inline: auto;
    padding-inline: var(--outer-margin-mobile);
  }

  @media (min-width: 768px) {
    .container-text {
      padding-inline: var(--outer-margin);
    }
  }

  .article-header {
    margin-top: var(--space-6);
  }

  .article-header__category {
    font-family: var(--font-en);
    font-size: var(--text-sm);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .article-header__title {
    margin-top: var(--space-3);
    font-size: var(--text-3xl-mobile);
    line-height: var(--leading-tight);
  }

  @media (min-width: 768px) {
    .article-header__title {
      font-size: var(--text-3xl);
    }
  }

  .article-header__lead {
    margin-top: var(--space-4);
    font-size: var(--text-lg);
    color: var(--color-ink-secondary);
  }

  .article-header__meta {
    margin-top: var(--space-4);
    display: flex;
    gap: var(--space-4);
    font-size: var(--text-xs);
    color: var(--color-ink-tertiary);
  }

  .article-header__tags {
    margin-top: var(--space-4);
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .article-header :global(.pr-label) {
    margin-top: var(--space-4);
  }

  /*
   * 実バグ修正: aspect-ratioをimg要素自身に指定すると、img自身が持つ
   * width/height HTML属性(Astro Imageが常に出力する)の影響で高さの
   * auto計算がaspect-ratioより属性値のheightを優先してしまい、
   * 幅だけコンテナに収まって高さは属性値のまま(=極端に縦長)になる
   * 不具合があった(モバイル幅で顕在化)。サイト内の他の画像
   * (ArticleCard/ProductCard/Hero.astro等)は例外なく「ラッパー要素に
   * aspect-ratio、imgはwidth/height100%+object-fit:cover」という
   * パターンで実装されており問題が起きていなかったため、同じパターンに
   * 統一した。
   */
  .article-hero {
    margin-top: var(--space-6);
    aspect-ratio: 3 / 2;
    overflow: hidden;
  }

  .article-hero img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .article-body {
    margin-top: var(--space-7);
  }

  /*
   * 26章c9: ≥1024pxはTocをaside配置のsticky sidebarにする。
   * 本文の可読幅(680px)はそのまま保ち、TOC分(240px+gap)だけ全体の
   * max-widthを広げる(680+48+240=968px)ことで、本文自体のリフロー・
   * レイアウトシフトを起こさない。TocはDOM上でProse/ShareRowより前にある
   * ため、明示的にgrid-column:2を指定しないと自動配置で1列目に来てしまう。
   * Prose/ShareRowは無指定のままgrid-row:1に自動配置されるため、行の高さは
   * 本文の高さに揃い、sticky sidebarが本文の高さ分だけ追従できる。
   */
  @media (min-width: 1024px) {
    .article-body.container-text {
      max-width: 968px;
      display: grid;
      grid-template-columns: 1fr 240px;
      column-gap: var(--space-6);
      align-items: start;
    }

    .article-body :global(.toc) {
      grid-column: 2;
      grid-row: 1;
      align-self: start;
      position: sticky;
      top: calc(var(--header-height-desktop) + var(--space-6));
      margin-bottom: 0;
    }
  }

  .article-section {
    margin-top: var(--section-gap);
  }

  .article-section__heading {
    font-size: var(--text-2xl);
    margin-bottom: var(--space-5);
  }

  .article-section__scroll {
    display: flex;
    gap: var(--space-4);
    overflow-x: auto;
  }

  .article-section__scroll-item {
    flex: 0 0 200px;
  }

  .article-section__grid {
    display: grid;
    gap: var(--space-5);
    grid-template-columns: repeat(2, 1fr);
  }

  @media (min-width: 768px) {
    .article-section__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
